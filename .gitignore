# Dependencies
node_modules/
bun.lockb

# Build output
dist/
build/

# Session data (local only)
data/sessions/*.jsonl
storage/

# Keep the sessions directory structure
!data/sessions/.gitkeep

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.sublime-*

# Logs
*.log
npm-debug.log*
.devlogs/

# Environment
.env
.env.local
.env.*.local

# MCP config (contains tokens)
.mcp.json

# Claude Code local settings
.claude/settings.local.json

# Agent expertise (auto-generated per session, FIFO-pruned)
.claude/agent-memory/*/EXPERTISE.md

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.cache/

# Claude Code temporary files
tmpclaude-*-cwd

# Claude Code metrics (runtime data)
**/.claude/metrics/

# Trace data
.claude/traces/

# Context registry (runtime data)
.claude/.context-registry.json

# Runtime data directories
data/
!data/sessions/.gitkeep

# Test results (Playwright/runner artifacts)
test-results/

# Windows shell artifact
nul

# Generated reports
*.html
poneglyph-analysis.md

# Specs (design documents, not part of distributed config)
.specs/

# Poneglyph self-referential (only for developing Poneglyph itself)
.claude/commands/insights-poneglyph.md

# Project-level skills (not deployed globally)
.claude/skills/bun-best-practices/
.claude/skills/typescript-patterns/
.claude/skills/testing-strategy/
.claude/skills/websocket-patterns/
.claude/skills/code-style-enforcer/
.claude/skills/api-design/
.claude/skills/config-validator/
.claude/rules/skill-matching.md

# Project-level TS hooks (not deployed globally)
.claude/hooks/format-code.ts
.claude/hooks/typecheck-guard.ts
.claude/hooks/validators/ast/
.claude/hooks/validators/typescript/
.claude/hooks/validators/code-quality/lint-validator.ts
