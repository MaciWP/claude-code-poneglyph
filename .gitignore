# Dependencies
node_modules/
bun.lockb

# Build output
dist/
build/
# Exception: .claude/skills/build/ is the Phase 3 implementation skill, not build output
!.claude/skills/build/
!.claude/skills/build/**

# Session data (local only)
data/sessions/*.jsonl
storage/

# Keep the sessions directory structure
!data/sessions/.gitkeep

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE
.vscode/
.idea/
*.sublime-*

# Logs
*.log
npm-debug.log*
.devlogs/

# Environment
.env
.env.local
.env.*.local

# MCP config (contains tokens)
.mcp.json

# Claude Code local settings
.claude/settings.local.json

# Per-machine settings overlay (env.PATH etc.) — sync-claude deep-merges it into the
# generated ~/.claude/settings.json. Each machine keeps its own; never committed.
.claude/settings.machine.json

# Agent memory (auto-generated per session, FIFO-pruned; builder/MEMORY.md is tracked intentionally)
.claude/agent-memory/*/MEMORY.md
!.claude/agent-memory/builder/MEMORY.md

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
.cache/

# Claude Code temporary files
tmpclaude-*-cwd

# Claude Code metrics (runtime data)
**/.claude/metrics/

# Trace data
.claude/traces/

# Context registry (runtime data)
.claude/.context-registry.json

# Archived plans (closed/abandoned features — out of accidental read reach)
.claude/plans/_archive/

# Learning inbox + load-layer log (may contain transcript snippets — never commit)
.claude/learned/

# Runtime data directories
data/
!data/sessions/.gitkeep

# Test results (Playwright/runner artifacts)
test-results/

# Windows shell artifact
nul

# Generated reports
*.html
poneglyph-analysis.md
# Exception: usage dashboard template (source, not generated)
!.claude/scripts/dashboard-template.html
# Exception: the whole html-report skill templates dir is SOURCE (approved designs,
# the templates meant to be used), never generated renders. Whole-dir exception so new
# templates are versioned without re-arming the *.html rule (it ate deliverables 2x).
!.claude/skills/html-report/templates/**

# Specs (design documents, not part of distributed config)
.specs/

# ccstatusline scratch files (settings.json is intentionally tracked)
.claude/ccstatusline/*.bak
.claude/ccstatusline/settings.bak
.claude/ccstatusline/*.tmp

# Poneglyph self-referential (only for developing Poneglyph itself)
.claude/commands/insights-poneglyph.md

# Project-level skills (not deployed globally)
.claude/skills/bun-best-practices/
.claude/skills/typescript-patterns/
.claude/skills/testing-strategy/
.claude/skills/websocket-patterns/
.claude/skills/api-design/
.claude/skills/config-validator/
.claude/rules/skill-matching.md

# Project-level TS hooks (not deployed globally)
.claude/hooks/format-code.ts
.claude/hooks/typecheck-guard.ts
.claude/hooks/validators/ast/
.claude/hooks/validators/typescript/
.claude/hooks/validators/code-quality/lint-validator.ts
