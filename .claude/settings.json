{
  "respectGitignore": true,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "ENABLE_LSP_TOOL": "1",
    "PATH": "/c/Users/Maci/.bun/bin:${HOME}/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin:/usr/sbin:/sbin:/c/Program Files/nodejs:./node_modules/.bin:${PATH}",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "50000",
    "CLAUDE_LEAD_MODE": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill",
      "AskUserQuestion",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "LSP",
      "NotebookEdit"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "model": "sonnet[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/memory-inject.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/code-validator.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/format/json-validator.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/context/record-read.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/context/update-after-write.ts"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/context-virtualizer.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/tool-timer.ts",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/tool-timer.ts",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/stop/validate-tests-pass.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/trace-logger.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/session-digest.ts",
            "timeout": 10000,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/security-gate.ts",
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/utils/cleanup-optimization-history.ts",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/lead-enforcement.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/context/check-staleness.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/lead-parallelism-gate.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/pre-compact.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/post-compact.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/instructions-loaded.ts",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/agent-scoring.ts",
            "timeout": 10000,
            "async": true
          },
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/retrospective-logger.ts",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/subagent-start.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/error-recorder.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/error-recorder.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/auto-approve.ts",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.bun/bin/ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true
  },
  "language": "spanish",
  "sandbox": {
    "enabled": false
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Pensando",
      "Analizando",
      "Investigando",
      "Procesando",
      "Evaluando",
      "Planificando",
      "Construyendo",
      "Revisando",
      "Optimizando"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "autoCompactEnabled": false,
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".venv"
    ]
  }
}
