{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "ENABLE_LSP_TOOL": "1",
    "PATH": "/c/Users/Maci/.bun/bin:${HOME}/.bun/bin:/c/Users/Maci/AppData/Roaming/npm:/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin:/usr/sbin:/sbin:/c/Program Files/nodejs:./node_modules/.bin:${PATH}",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "50000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill",
      "AskUserQuestion",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "LSP",
      "NotebookEdit",
      "Agent",
      "SendMessage",
      "mcp__context7__*"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * -O - | sh)",
      "Bash(wget * -O - | bash)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(.env)",
      "Edit(*.pem)",
      "Edit(*credentials*)",
      "Edit(*secret*)",
      "Write(.env)",
      "Write(*.pem)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/code-validator.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/security-gate.ts",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/post-compact.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/auto-approve.ts",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".venv"
    ],
    "baseRef": "head"
  },
  "statusLine": {
    "type": "command",
    "command": "C:/Users/Maci/.bun/bin/ccstatusline.exe",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "mcpServers": {
    "cclsp": {
      "command": "C:\\Program Files\\nodejs\\node.exe",
      "args": [
        "C:\\Users\\Maci\\AppData\\Roaming\\npm\\node_modules\\cclsp\\dist\\index.js"
      ],
      "env": {
        "CCLSP_CONFIG_PATH": "C:\\Users\\Maci\\.claude\\cclsp.json"
      }
    }
  },
  "language": "spanish",
  "effortLevel": "xhigh",
  "sandbox": {
    "enabled": false
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Pensando",
      "Analizando",
      "Investigando",
      "Procesando",
      "Evaluando",
      "Planificando",
      "Construyendo",
      "Revisando",
      "Optimizando"
    ]
  },
  "advisorModel": "opus",
  "promptSuggestionEnabled": false,
  "awaySummaryEnabled": false,
  "agentPushNotifEnabled": false,
  "remoteControlAtStartup": false,
  "preferredNotifChannel": "iterm2_with_bell",
  "editorMode": "normal",
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "hard_deny": [
      "Bash(rm -rf .claude)",
      "Bash(rm -rf .claude/*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ],
    "soft_deny": [
      "$defaults",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Bash(rm .claude)"
    ]
  }
}
