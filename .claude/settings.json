{
  "respectGitignore": true,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "ENABLE_LSP_TOOL": "1",
    "PATH": "/c/Users/Maci/.bun/bin:${HOME}/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin:/usr/sbin:/sbin:/c/Program Files/nodejs:./node_modules/.bin:${PATH}",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "50000",
    "CLAUDE_LEAD_MODE": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill",
      "AskUserQuestion",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "LSP",
      "NotebookEdit",
      "Agent",
      "SendMessage"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/validators/code-validator.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/security-gate.ts",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/lead-enforcement.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/post-compact.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/auto-approve.ts",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      "node_modules",
      ".venv"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.bun/bin/ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "language": "spanish",
  "sandbox": {
    "enabled": false
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Pensando",
      "Analizando",
      "Investigando",
      "Procesando",
      "Evaluando",
      "Planificando",
      "Construyendo",
      "Revisando",
      "Optimizando"
    ]
  },
  "advisorModel": "opus",
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "soft_deny": [
      "$defaults",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Bash(rm .claude)",
      "Bash(rm -rf .claude)"
    ]
  }
}
