{
  "respectGitignore": true,
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "ENABLE_LSP_TOOL": "1",
    "PATH": "/c/Users/Maci/.bun/bin:${HOME}/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/bin:/usr/bin:/usr/sbin:/sbin:/c/Program Files/nodejs:./node_modules/.bin:${PATH}",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "50000",
    "CLAUDE_LEAD_MODE": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill",
      "AskUserQuestion",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "LSP",
      "NotebookEdit"
    ],
    "deny": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/memory-inject.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "if": "Edit(*.ts)|Edit(*.tsx)|Edit(*.js)|Edit(*.jsx)|Edit(*.py)|Write(*.ts)|Write(*.tsx)|Write(*.js)|Write(*.jsx)|Write(*.py)",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/code-quality/complexity-validator.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/security/secrets-validator.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/security/injection-validator.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/format/json-validator.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/context/record-read.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/context/update-after-write.ts"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/context-virtualizer.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/stop/validate-tests-pass.ts"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/trace-logger.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/session-digest.ts",
            "timeout": 10000,
            "async": true
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/stop/validate-file-contains.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bun $HOME/.claude/hooks/lead-enforcement.ts",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/validators/context/check-staleness.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/post-compact.ts",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/agent-scoring.ts",
            "timeout": 10000,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/subagent-start.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/permission-denied.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/api-error-recorder.ts",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run $HOME/.claude/hooks/auto-approve.ts",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun $HOME/.claude/hooks/statusline.ts",
    "padding": 0
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true
  },
  "language": "es",
  "sandbox": {
    "enabled": false
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Pensando",
      "Analizando",
      "Investigando",
      "Procesando",
      "Evaluando",
      "Planificando",
      "Construyendo",
      "Revisando",
      "Optimizando"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
